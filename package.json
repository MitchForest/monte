{
  "name": "monte",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "biome format --write .",
    "db:migrate": "bun --filter @monte/database db:migrate",
    "db:codegen": "bun --filter @monte/database db:codegen"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "packageManager": "bun@1.1.0",
  "dependencies": {
    "better-auth": "^1.3.10"
  }
}

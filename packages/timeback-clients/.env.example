# TimeBack client configuration lives alongside the package. Copy to .env and
# provide credentials before running fetch-specs or generate.

# TimeBack integration
TIMEBACK_ENVIRONMENT=staging

# Staging credentials (required for roster/XPs in non-production builds)
STAGING_CLIENT_ID=
STAGING_CLIENT_SECRET=
STAGING_AUTH_API=https://alpha-auth-development-idp.auth.us-west-2.amazoncognito.com
QTI_STAGING_API_URL=https://qti-staging.alpha-1edtech.com/
ONEROSTER_STAGING_API_URL=https://api.staging.alpha-1edtech.com/
CALIPER_STAGING_API_URL=https://caliper-staging.alpha-1edtech.com/
POWERPATH_STAGING_API_URL=https://staging.alpha-1edtech.com/

# Leave production values unset until you intentionally target prod
PROD_CLIENT_ID=
PROD_CLIENT_SECRET=
PROD_AUTH_API=https://alpha-auth-production-idp.auth.us-west-2.amazoncognito.com
QTI_PROD_API_URL=https://qti.alpha-1edtech.com
ONEROSTER_PROD_API_URL=https://api.alpha-1edtech.com/
CALIPER_PROD_API_URL=https://caliper.alpha-1edtech.com/
POWERPATH_PROD_API_URL=https://api.alpha-1edtech.com/
{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": ["NODE_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_*",
        "OPENAI_API_KEY",
        "RESEND_*",
        "DATABASE_URL"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "PORT",
        "API_URL",
        "APP_ORIGINS",
        "NEXT_PUBLIC_*",
        "DATABASE_URL",
        "OPENAI_API_KEY",
        "RESEND_*",
        "QTI_*",
        "ONEROSTER_*",
        "CALIPER_*",
        "TIMEBACK_*"
      ]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "env": ["DATABASE_URL"]
    },
    "db:codegen": {
      "cache": false,
      "env": ["DATABASE_URL"]
    }
  }
}

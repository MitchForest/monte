{
  "name": "@monte/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file=.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run --env-file=.env dist/index.js",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/zod-openapi": "^1.1.1",
    "@monte/database": "workspace:*",
    "@monte/shared": "workspace:*",
    "hono": "^4.9.7",
    "jose": "^6.1.0",
    "openai": "^4.72.0",
    "resend": "^4.5.0",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}

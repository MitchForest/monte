{
  "name": "@monte/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file=../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run --env-file=../../.env dist/index.js",
    "typecheck": "bun x tsc --noEmit",
    "lint": "bun x biome check"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@monte/database": "workspace:*",
    "@monte/shared": "workspace:*",
    "better-auth": "^1.3.10",
    "hono": "^4.6.18",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}

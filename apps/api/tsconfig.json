{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["bun-types", "@asteasolutions/zod-to-openapi"],
    "lib": ["ES2022", "dom"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@monte/api": ["./src/index.ts"],
      "@monte/api/*": ["./src/*"],
      "@monte/shared": ["../../packages/shared/src/index.ts"],
      "@monte/shared/*": ["../../packages/shared/src/*"],
      "@monte/timeback-clients": ["../../packages/timeback-clients/src/index.ts"],
      "@monte/timeback-clients/*": ["../../packages/timeback-clients/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "types/**/*.d.ts",
    "types/**/*.ts",
    "../../packages/shared/src/**/*",
    "../../packages/database/src/**/*",
    "../../packages/timeback-clients/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}

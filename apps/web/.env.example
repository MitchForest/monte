# Next.js App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# Timeback SSO (staging defaults)
NEXT_PUBLIC_COGNITO_AUTHORITY=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
NEXT_PUBLIC_COGNITO_SCOPE=openid email profile
NEXT_PUBLIC_COGNITO_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_COGNITO_LOGOUT_URI=http://localhost:3000

# Dev convenience (optional mock mode)
NEXT_PUBLIC_AUTH_MOCK=false
NEXT_PUBLIC_DEV_ACCESS_TOKEN=dev-token
NEXT_PUBLIC_DEV_USER_EMAIL=guide@example.com
NEXT_PUBLIC_DEV_USER_NAME=Guide User

# OpenAI (for STT and generation features)
OPENAI_API_KEY=
